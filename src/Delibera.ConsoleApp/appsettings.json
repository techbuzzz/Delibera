{
  "ConnectionStrings": {
    "PostgreSQL": "Host=localhost;Database=council_vectors;Username=postgres;Password=postgres"
  },

  "Delibera": {
    "Strategy": "Standard",
    "MaxRounds": 4,
    "Temperature": 0.7,
    "SystemPrompt": "You are a knowledgeable AI expert participating in a council debate. Provide thorough, well-reasoned answers.",
    "ResponseLanguage": "Russian",
    "MaxDegreeOfParallelism": 0,

   "Providers": {
      "DefaultType": "Ollama",
      "DefaultEndpoint": "https://api.ollama.com",
      "ApiKey": "YOUR_OLLAMA_CLOUD_API_KEY",
      "EmbeddingModel": "nomic-embed-text"
   },

    "Compression": {
      "Enabled": true,
      "Strategy": "Hybrid",
      "TargetRatio": 0.5,
      "EnableCache": true,
      "MaxCacheEntries": 256
    },

    "Rag": {
      "Enabled": false,
      "ProviderType": "Qdrant",
      "Host": "localhost",
      "Port": 6334,
      "CollectionName": "council_knowledge"
    },

    "Output": {
      "Directory": "./debate_results",
      "SeparateFiles": true,
      "FilePrefix": null
    }
  },

  "DeliberaApp": {
    "Providers": {
      "OllamaCloud": {
        "Type": "Ollama",
        "Endpoint": "https://api.ollama.com",
        "ApiKey": "YOUR_OLLAMA_CLOUD_API_KEY"
      }
    },

    "Qdrant": {
      "Host": "localhost",
      "Port": 6334,
      "CollectionName": "council_knowledge"
    },

    "PostgreSQL": {
      "ConnectionString": "Host=localhost;Database=council_vectors;Username=postgres;Password=postgres",
      "CollectionName": "council_pgvector"
    },

   "KnowledgeKeeper": {
      "Model": "llama2",
      "Provider": "OllamaLocal",
      "EmbeddingModel": "nomic-embed-text"
   },

   "Chairman": {
      "Model": "gemma4:cloud",
      "Provider": "OllamaCloud",
      "Type": "Standard",
      "EnableClarifyingQuestions": true,
      "MaxDebateRounds": 5
   },

    "Models": [
      {
         "Name": "llama2",
         "Provider": "OllamaLocal",
         "Role": "Expert",
         "Persona": "You are a thorough and analytical expert. You provide well-structured, evidence-based answers with clear reasoning."
      },
      {
         "Name": "qwen2.5:7b",
         "Provider": "OllamaLocal",
         "Role": "Expert",
         "Persona": "You are a creative and insightful expert. You approach problems from unique angles and provide innovative solutions."
      }
    ],

    "Debate": {
      "Strategy": "Standard",
      "MaxRounds": 4,
      "Temperature": 0.7,
      "OutputDirectory": "./debate_results",
      "ResponseLanguage": "Russian",
      "MaxDegreeOfParallelism": 0
    },

    "ContextCompression": {
      "Enabled": true,
      "Strategy": "Hybrid",
      "TargetRatio": 0.5,
      "MaxOutputTokens": null,
      "PreserveCodeBlocks": true,
      "PreserveStructuredContent": true,
      "DeduplicationThreshold": 0.85,
      "SummarizationTemperature": 0.3,
      "Cache": {
        "Enabled": true,
        "MaxEntries": 256
      }
    },

    "TokenOptimization": {
      "CharsPerToken": 4.0,
      "TrackStatistics": true,
      "WarnOnHighTokenUsage": true,
      "HighUsageThresholdTokens": 100000
    },

    "Knowledge": {
      "Enabled": true,
      "Files": [
        "./knowledge/context.md"
      ]
    },

    "Prompts": {
      "SystemPrompt": "You are a knowledgeable AI expert participating in a council debate. Provide thorough, well-reasoned answers. Support your arguments with evidence and logical reasoning.",
      "UserPrompt": "What are the key advantages and disadvantages of microservices architecture compared to monolithic architecture? When should each approach be used?"
    }
  }
}
